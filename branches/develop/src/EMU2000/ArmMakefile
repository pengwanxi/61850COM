all:
	 @list='$(SUBDIRS)'; for subdir in $$list; do \
                echo "Making all in $$list"; \
                (cd $$subdir && make -f ArmMakefile all -j4 ) ;  \
		 if [ $$? -ne 0 ]; then echo stoped complie ; break; \
                 fi; \
				 echo -e "\n" ; \
        done; 
.PHONY: clean
clean:
	@list='$(SUBDIRS)'; for subdir in $$list; do \
                echo "Clean in $$subdir"; \
                (cd $$subdir && make -f ArmMakefile clean -j4); \
				echo -e "\n" ; \
       done
distclean:
	@list='$(SUBDIRS)'; for subdir in $$list; do \
                echo "Clean in $$subdir"; 		\
                (cd $$subdir && make -f ArmMakefile distclean -j4); \
				echo -e "\n" ; \
        done
